{
    // CMD + SHIFT + B -------> To Compile and Run Leaks using in.txt as input
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compile and Run Leaks (with in.txt)",
            "type": "shell",
            "command": "clang -g '${file}' -o '${fileDirname}/${fileBasenameNoExtension}' && env MallocStackLogging=1 leaks --atExit -- '${fileDirname}/${fileBasenameNoExtension}' < '${fileDirname}/in.txt'",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}